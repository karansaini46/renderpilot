{
  "name": "renderpilot-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first architectural rendering and visualization orchestration platform",
  "workspaces": [
    "apps/web",
    "apps/api",
    "apps/worker",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "start:web": "npm run start --workspace=apps/web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
