# RenderPilot Configuration Options Template

# Database Connection (Neon PostgreSQL cloud database link)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Object Storage configurations for large files and renders
STORAGE_PROVIDER=cloudflare_r2
STORAGE_BUCKET=renderpilot-assets
STORAGE_PUBLIC_BASE_URL=https://pub-your-id.r2.dev

# Private AWS S3 configuration
AWS_REGION=us-east-1
AWS_S3_BUCKET=renderpilot-private-bucket
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Laptop Worker unique ID and integration paths
WORKER_ID=laptop_node_01
WORKER_NAME=Laptop Workstation 01
COMFYUI_URL=http://127.0.0.1:8188
BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 4.1\blender.exe
LOCAL_WORKSPACE_ROOT=C:\Users\Vaidehi\Desktop\renderpilot\storage

# Worker resource locks and concurrency controls
MAX_CONCURRENT_LOCAL_JOBS=1
LOCAL_RESOURCE_LOCK_ENABLED=true
LOCAL_RESOURCE_LOCK_TIMEOUT_MINUTES=60
LOCAL_PROMPT_MODEL_ENABLED=false

# PromptBrain Settings
PROMPT_BRAIN_PROVIDER=gemini
PROMPT_BRAIN_FALLBACK=manual
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PROMPT_BRAIN_TIMEOUT_MS=20000
PROMPT_BRAIN_MIN_CONFIDENCE=0.75
PROMPT_BRAIN_CACHE_ENABLED=false
GEMINI_PROMPT_ENHANCER_ENABLED=true



